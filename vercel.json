{
  "rewrites": [
    {
      "source": "/assets/:path*",
      "destination": "/assets/:path*"
    },
    {
      "source": "/tape-q-and-a",
      "destination": "/tape-q-and-a.html"
    },
    {
      "source": "/qa",
      "destination": "/tape-q-and-a.html"
    },
    {
      "source": "/favicon.png",
      "destination": "/favicon.png"
    },
    {
      "source": "/og-image.png",
      "destination": "/og-image.png"
    },
    {
      "source": "/robots.txt",
      "destination": "/robots.txt"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/sitemap.xml"
    },
    {
      "source": "/lto-tape-price-trend/lto10-price",
      "destination": "/lto10-price.html"
    },
    {
      "source": "/lto-tape-price-trend/lto9-price",
      "destination": "/lto9-price.html"
    },
    {
      "source": "/lto-tape-price-trend/lto8-price",
      "destination": "/lto8-price.html"
    },
    {
      "source": "/lto-tape-price-trend/lto7-price",
      "destination": "/lto7-price.html"
    },
    {
      "source": "/lto-tape-price-trend/lto6-price",
      "destination": "/lto6-price.html"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ],
  "redirects": [
    {
      "source": "/news",
      "destination": "/tape-q-and-a",
      "permanent": true
    },
    {
      "source": "/questions",
      "destination": "/tape-q-and-a",
      "permanent": true
    }
  ],
  "headers": [
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
